# Copy to .env for local Docker, or set these in Render → Environment.
# .env is NOT deployed to Render — you must add every value in the Render dashboard.

CRAFT_APP_ID=CraftCMS--54029edf-ef83-4931-afca-0e572d173ed4
CRAFT_ENVIRONMENT=production
CRAFT_SECURITY_KEY=change-me
CRAFT_DEV_MODE=false

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-icon.png">
<link rel="apple-touch-icon" sizes="60x60" href="/apple-icon-60x60.png">
<link rel="icon" type="image/png" sizes="48x48" href="/android-icon-48x48.png">
<link rel="icon" type="image/png" sizes="36x36" href="/android-icon-36x36.png">
<title>{% block title %}Golden Haze Films — Turning Moments into Ricordi d'Oro{% endblock %}</title>
<meta name="description" content="{% block metaDescription %}Golden Haze Films — Premium Wedding Videography, Cinematic Films & Creative Digital Experiences from Jabalpur, India.{% endblock %}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Manrope:wght@300;400;500;600&family=Dancing+Script:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/index.css">
{% block head %}{% endblock %}
</head>
<body>

<!-- CURSOR -->
<div id="cursor-dot"></div>
<div id="cursor-ring"></div>

<!-- SCROLL PROGRESS -->
<div id="progress-bar"></div>

<!-- GRAIN -->
<div id="grain"></div>

{% include '_partials/header.twig' %}

{% block content %}{% endblock %}

{% include '_partials/footer.twig' %}

<script src="/js/index.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>

</section>


<!-- =============================================
     TESTIMONIALS
     ============================================= -->
{% set testimonialsBlock = entry is defined ? entry.testimonials.one() : null %}
<section id="testimonials">
  <div class="testimonials-inner">
    <div class="testimonials-header">
      <div class="section-label reveal" style="justify-content:center">{{ testimonialsBlock ? testimonialsBlock.eyebrow|default('Client Stories') : 'Client Stories' }}</div>
      <h2 class="testimonials-h2 reveal reveal-delay-1">
        {% if testimonialsBlock and testimonialsBlock.heading %}
          {{ macros.headingWithBreaks(testimonialsBlock.heading)|raw }}
        {% else %}
          Words of <em>Gold</em>
        {% endif %}
      </h2>
    </div>

    <div class="testimonials-slider reveal reveal-delay-2">
      <div class="testimonials-track" id="tTrack">
        {% if testimonialsBlock and testimonialsBlock.relatedTestimonials|length %}
          {% for testimonial in testimonialsBlock.relatedTestimonials.all() %}
            <div class="testimonial-slide">
              <span class="testimonial-quote-mark">"</span>
              <p class="testimonial-text">{{ testimonial.quate }}</p>
              <div class="testimonial-author">
                <div class="testimonial-avatar">{{ testimonial.clientName|slice(0, 1)|upper }}</div>
                <div class="testimonial-info">
                  <div class="testimonial-name">{{ testimonial.clientName }}</div>
                  <div class="testimonial-role">{{ testimonial.shortDescription }}</div>
                </div>
              </div>
            </div>
          {% endfor %}
        {% else %}
        <div class="testimonial-slide">
          <span class="testimonial-quote-mark">"</span>
          <p class="testimonial-text">Golden Haze Films didn't just film our wedding — they created a work of art. Every frame, every edit, every musical choice felt deeply intentional. When we watch our film, we relive every emotion as if it were yesterday.</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">A</div>
            <div class="testimonial-info">
              <div class="testimonial-name">Aryan &amp; Priya Sharma</div>
              <div class="testimonial-role">Wedding Film Client · Jabalpur</div>
            </div>
          </div>
        </div>

        <div class="testimonial-slide">
          <span class="testimonial-quote-mark">"</span>
          <p class="testimonial-text">The branding they created for my jewellery label was beyond what I imagined. They understood the soul of my brand and translated it into a visual identity that speaks luxury. Truly a world-class team in Jabalpur.</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">N</div>
            <div class="testimonial-info">
              <div class="testimonial-name">Nidhi Agarwal</div>
              <div class="testimonial-role">Founder, Elara Jewels · Bhopal</div>
            </div>
          </div>
        </div>

        <div class="testimonial-slide">
          <span class="testimonial-quote-mark">"</span>
          <p class="testimonial-text">From the pre-wedding shoot to the final film, every interaction with the Golden Haze team was exceptional. They have an extraordinary ability to capture emotion. Our wedding film has made our entire family cry — with joy.</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">R</div>
            <div class="testimonial-info">
              <div class="testimonial-name">Rohan &amp; Simran Mehta</div>
              <div class="testimonial-role">Wedding Film Client · Bhopal</div>
            </div>
          </div>
        </div>
        {% endif %}
      </div>
    </div>

    <div class="t-arrows">
      <button class="t-arrow" id="tPrev" aria-label="Previous">←</button>
      <button class="t-arrow" id="tNext" aria-label="Next">→</button>
    </div>
    <div class="testimonials-nav" id="tDots">
      {% if testimonialsBlock and testimonialsBlock.relatedTestimonials|length %}
        {% for testimonial in testimonialsBlock.relatedTestimonials.all() %}
          <div class="t-dot{{ loop.first ? ' active' : '' }}"></div>
        {% endfor %}
      {% else %}
        <div class="t-dot active"></div>
        <div class="t-dot"></div>
        <div class="t-dot"></div>
      {% endif %}
    </div>
  </div>
</section>


<!-- =============================================
     CONTACT CTA + FORM
     ============================================= -->
<section id="contact-cta">
  <div class="contact-cta-inner">
    <div class="cta-left">
      <div class="section-label reveal">Get In Touch</div>
      <h2 class="cta-h2 reveal reveal-delay-1">
        Let's Create<br>
        <em>Something<br>Extraordinary</em>
      </h2>
      <p class="cta-sub reveal reveal-delay-2">Every great story begins with a conversation. Reach out to our team and let us understand your vision — we will bring it to life with Golden craftsmanship.</p>

      <div class="contact-links reveal reveal-delay-3">
        <a href="tel:+918349820587" class="contact-link">
          <div class="contact-link-icon">📞</div>
          <span>+91 8349820587</span>
        </a>
        <a href="mailto:filmsgoldenhaze@gmail.com" class="contact-link">
          <div class="contact-link-icon">✉</div>
          <span>filmsgoldenhaze@gmail.com</span>
        </a>
        <a href="https://instagram.com/goldenhazefilms" class="contact-link">
          <div class="contact-link-icon">{{ macros.instagramIcon() }}</div>
          <span>@goldenhazefilms</span>
        </a>
        <a href="https://wa.me/918349820587" class="contact-link">
          <div class="contact-link-icon">{{ macros.whatsappIcon() }}</div>
          <span>WhatsApp Us</span>
        </a>
        <div class="contact-link">
          <div class="contact-link-icon">📍</div>
          <span>Jabalpur, Madhya Pradesh, India</span>
        </div>
      </div>
    </div>

    <div class="contact-form-wrap reveal reveal-delay-2">
      <form class="contact-form" id="contact-form" method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('contactform/submit/send') }}
        {{ redirectInput(craft.app.request.url|split('#')|first ~ '#contact-cta') }}

        {% if craft.app.session.hasFlash('contactSuccess') %}
          <div class="form-notice form-notice--success">✦ Message sent — we'll be in touch soon.</div>
        {% endif %}
        {% if craft.app.session.hasFlash('contactError') %}
          <div class="form-notice form-notice--error">{{ craft.app.session.getFlash('contactError') }}</div>
        {% endif %}

        <h3 class="form-title">Send Us a Message</h3>
        <div class="form-row">
          <div class="form-group">
            <label for="firstName">First Name</label>
            <input type="text" id="firstName" name="firstName" placeholder="Aarav" required value="{{ craft.app.request.getBodyParam('firstName') }}">
          </div>
          <div class="form-group">
            <label for="lastName">Last Name</label>
            <input type="text" id="lastName" name="lastName" placeholder="Sharma" required value="{{ craft.app.request.getBodyParam('lastName') }}">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="phoneNumber">Phone Number</label>
            <input type="tel" id="phoneNumber" name="phoneNumber" placeholder="+91 98765 43210" required value="{{ craft.app.request.getBodyParam('phoneNumber') }}">
          </div>
          <div class="form-group">
            <label for="emailAddress">Email Address</label>
            <input type="email" id="emailAddress" name="emailAddress" placeholder="hello@example.com" required value="{{ craft.app.request.getBodyParam('emailAddress') }}">
          </div>
        </div>
        <div class="form-group">
          <label for="serviceInterestedIn">Service Interested In</label>
          <select id="serviceInterestedIn" name="serviceInterestedIn">
            <option value="">Select a Service</option>
            {% set selectedService = craft.app.request.getBodyParam('serviceInterestedIn') %}
            <option value="Wedding Videography"{{ selectedService == 'Wedding Videography' ? ' selected' : '' }}>Wedding Videography</option>
            <option value="Wedding Photography"{{ selectedService == 'Wedding Photography' ? ' selected' : '' }}>Wedding Photography</option>
            <option value="Pre-Wedding Shoot"{{ selectedService == 'Pre-Wedding Shoot' ? ' selected' : '' }}>Pre-Wedding Shoot</option>
            <option value="Video Editing"{{ selectedService == 'Video Editing' ? ' selected' : '' }}>Video Editing</option>
            <option value="Album Designing"{{ selectedService == 'Album Designing' ? ' selected' : '' }}>Album Designing</option>
            <option value="Brand Development"{{ selectedService == 'Brand Development' ? ' selected' : '' }}>Brand Development</option>
            <option value="Graphic Design"{{ selectedService == 'Graphic Design' ? ' selected' : '' }}>Graphic Design</option>
            <option value="Web Development"{{ selectedService == 'Web Development' ? ' selected' : '' }}>Web Development</option>
            <option value="Commercial Shoot"{{ selectedService == 'Commercial Shoot' ? ' selected' : '' }}>Commercial Shoot</option>
            <option value="Social Media Content"{{ selectedService == 'Social Media Content' ? ' selected' : '' }}>Social Media Content</option>
          </select>
        </div>
        <div class="form-group">
          <label for="yourMessage">Your Message</label>
          <textarea id="yourMessage" name="yourMessage" placeholder="Tell us about your vision, event date, or any specific requirements…">{{ craft.app.request.getBodyParam('yourMessage') }}</textarea>
        </div>
        <button type="submit" class="form-submit">Send Message</button>
      </form>
    </div>
  </div>
</section>
{% endblock %}
